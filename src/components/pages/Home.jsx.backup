import { useState, useEffect, useCallback } from "react";
import { Link, useNavigate } from "react-router-dom";
import { motion } from "framer-motion";
import { apiUrl } from "../../api/api";
import { 
  FiTrendingUp, 
  FiUsers, 
  FiAward, 
  FiDollarSign,
  FiStar,
  FiArrowRight,
  FiCheck,
  FiZap,
  FiShield,
  FiGlobe
} from "react-icons/fi";
import {
  AnimatedPage,
  StaggerContainer,
  StaggerItem,
  CountUp
} from "../animations/AnimatedComponents";

export default function Home() {
  const [contests, setContests] = useState([]);
  const [loading, setLoading] = useState(true);
  const [searchQuery, setSearchQuery] = useState("");
  const [stats, setStats] = useState({
    totalContests: 0,
    totalWinners: 0,
    totalPrizes: 0,
    activeUsers: 0
  });
  const navigate = useNavigate();

  // Check if user is logged in
  const isLoggedIn = localStorage.getItem("token");

  useEffect(() => {
    fetchPopularContests();
    fetchStats();
  }, []);

  const fetchPopularContests = async () => {
    try {
      const response = await fetch(apiUrl("/contests"));
      const data = await response.json();

      // Sort by participants count (highest first) and take top 6
      const sortedContests = (data.contests || [])
        .sort((a, b) => (b.participants?.length || 0) - (a.participants?.length || 0))
        .slice(0, 6);

      setContests(sortedContests);
    } catch (error) {
      console.error("Failed to fetch contests:", error);
      setContests([]);
    } finally {
      setLoading(false);
    }
  };

  const fetchStats = async () => {
    try {
      // Mock stats - replace with real API calls
      setStats({
        totalContests: 1250,
        totalWinners: 3400,
        totalPrizes: 185000,
        activeUsers: 12500
      });
    } catch (error) {
      console.error("Failed to fetch stats:", error);
    }
  };

  const handleSearch = useCallback(async (e) => {
    e.preventDefault();
    if (searchQuery.trim()) {
      navigate(`/all-contests?search=${encodeURIComponent(searchQuery)}`);
    }
  }, [searchQuery, navigate]);

  const handleDetailsClick = useCallback((contestId) => {
    if (!isLoggedIn) {
      navigate("/login");
    } else {
      navigate(`/contest/${contestId}`);
    }
  }, [isLoggedIn, navigate]);

  const features = [
    {
      icon: FiShield,
      title: "Secure & Fair",
      description: "All contests are judged fairly with transparent criteria and secure payment processing.",
      color: "from-blue-500 to-cyan-500"
    },
    {
      icon: FiZap,
      title: "Quick Payouts",
      description: "Winners receive their prizes within 24-48 hours through secure payment methods.",
      color: "from-purple-500 to-pink-500"
    },
    {
      icon: FiGlobe,
      title: "Global Community",
      description: "Connect with creators worldwide and participate in international competitions.",
      color: "from-green-500 to-teal-500"
    }
  ];

  const testimonials = [
    {
      name: "Sarah Johnson",
      role: "Graphic Designer",
      avatar: "https://images.unsplash.com/photo-1494790108755-2616b612b786?w=150",
      content: "ContestHub changed my career! I've won over $5,000 in prizes and gained amazing clients.",
      rating: 5,
      contest: "Logo Design Contest"
    },
    {
      name: "Mike Chen",
      role: "Web Developer",
      avatar: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=150",
      content: "The platform is incredibly user-friendly and the competition quality is top-notch.",
      rating: 5,
      contest: "Web Design Challenge"
    },
    {
      name: "Emma Davis",
      role: "Content Writer",
      avatar: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=150",
      content: "Perfect platform for writers! Fair judging and prompt payments every time.",
      rating: 5,
      contest: "Article Writing Contest"
    }
  ];

  return (
    <AnimatedPage>
      {/* Hero Section */}
      <section className="relative min-h-screen flex items-center justify-center overflow-hidden">
        {/* Background Image */}
        <div className="absolute inset-0">
          <img
            src="https://images.unsplash.com/photo-1570129477492-45c003edd2be?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80"
            alt="Modern House"
            className="w-full h-full object-cover"
          />
          {/* Dark overlay */}
          <div className="absolute inset-0 bg-black/40"></div>
        </div>

        <div className="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center z-10">
          <motion.div
            initial={{ opacity: 0, y: 30 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8 }}
            className="mb-8"
          >
            <h1 className="text-5xl md:text-7xl font-black mb-6 leading-tight text-white">
              <span className="block">Unleash Your </span>
              <span className="block text-green-400">Creativity</span>
              <span className="block mt-4">Win Amazing </span>
              <span className="block text-blue-400">Prizes</span>
            </h1>
          </motion.div>

          {/* Search Bar */}
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 0.2 }}
            className="max-w-2xl mx-auto mb-12"
          >
            <form onSubmit={handleSearch} className="relative">
              <div className="relative bg-white/90 backdrop-blur-sm rounded-full p-2 shadow-xl">
                <input
                  type="text"
                  value={searchQuery}
                  onChange={(e) => setSearchQuery(e.target.value)}
                  placeholder="Search contests (Logo, Web, Writing...)"
                  className="w-full px-6 py-4 text-lg bg-transparent text-gray-900 placeholder-gray-600 focus:outline-none rounded-full"
                />
                <motion.button
                  type="submit"
                  whileHover={{ scale: 1.05 }}
                  whileTap={{ scale: 0.95 }}
                  className="absolute right-2 top-1/2 -translate-y-1/2 bg-green-500 hover:bg-green-600 text-white px-6 py-3 rounded-full font-semibold transition-colors"
                >
                  Search
                </motion.button>
              </div>
            </form>
          </motion.div>

          {/* CTA Buttons */}
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.8, delay: 0.4 }}
            className="flex flex-col sm:flex-row gap-4 justify-center mb-16"
          >
            <motion.div whileHover={{ scale: 1.05 }} whileTap={{ scale: 0.95 }}>
              <Link 
                to="/all-contests" 
                className="inline-flex items-center justify-center px-8 py-4 bg-green-500 hover:bg-green-600 text-white text-lg font-semibold rounded-full transition-colors shadow-lg"
              >
                Browse All Contests
              </Link>
            </motion.div>

            {!isLoggedIn && (
              <motion.div whileHover={{ scale: 1.05 }} whileTap={{ scale: 0.95 }}>
                <Link 
                  to="/register" 
                  className="inline-flex items-center justify-center px-8 py-4 bg-white/20 hover:bg-white/30 backdrop-blur-sm text-white text-lg font-semibold rounded-full border-2 border-white/50 transition-all shadow-lg"
                >
                  Join Now — It's Free
                </Link>
              </motion.div>
            )}
          </motion.div>
        </div>
      </section>

      {/* Stats Section */}
      <section className="py-16 bg-white dark:bg-gray-900">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            className="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-4xl mx-auto"
          >
            <div className="text-center">
              <div className="text-3xl md:text-4xl font-bold gradient-text mb-2">
                <CountUp end={stats.totalContests} duration={2} />+
              </div>
              <div className="text-gray-600 dark:text-gray-400">Active Contests</div>
            </div>
            <div className="text-center">
              <div className="text-3xl md:text-4xl font-bold gradient-text mb-2">
                <CountUp end={stats.totalWinners} duration={2} />+
              </div>
              <div className="text-gray-600 dark:text-gray-400">Happy Winners</div>
            </div>
            <div className="text-center">
              <div className="text-3xl md:text-4xl font-bold gradient-text mb-2">
                $<CountUp end={stats.totalPrizes} duration={2} />+
              </div>
              <div className="text-gray-600 dark:text-gray-400">Prizes Awarded</div>
            </div>
            <div className="text-center">
              <div className="text-3xl md:text-4xl font-bold gradient-text mb-2">
                <CountUp end={stats.activeUsers} duration={2} />+
              </div>
              <div className="text-gray-600 dark:text-gray-400">Active Users</div>
            </div>
          </motion.div>
        </div>
      </section>
          >
            <div className="text-center">
              <div className="text-3xl md:text-4xl font-bold gradient-text mb-2">
                <CountUp end={stats.totalContests} duration={2} />+
              </div>
              <div className="text-gray-600 dark:text-gray-400">Active Contests</div>
            </div>
            <div className="text-center">
              <div className="text-3xl md:text-4xl font-bold gradient-text mb-2">
                <CountUp end={stats.totalWinners} duration={2} />+
              </div>
              <div className="text-gray-600 dark:text-gray-400">Happy Winners</div>
            </div>
            <div className="text-center">
              <div className="text-3xl md:text-4xl font-bold gradient-text mb-2">
                $<CountUp end={stats.totalPrizes} duration={2} />+
              </div>
              <div className="text-gray-600 dark:text-gray-400">Prizes Awarded</div>
            </div>
            <div className="text-center">
              <div className="text-3xl md:text-4xl font-bold gradient-text mb-2">
                <CountUp end={stats.activeUsers} duration={2} />+
              </div>
              <div className="text-gray-600 dark:text-gray-400">Active Users</div>
            </div>
          </motion.div>
        </div>
      </section>

      {/* Featured Contests Section */}
      <section className="py-20 bg-gray-50 dark:bg-gray-900/50">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            className="text-center mb-16"
          >
            <h2 className="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
              Featured Contests
            </h2>
            <p className="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto">
              Discover the most popular contests with amazing prizes and global participation
            </p>
          </motion.div>

          {loading ? (
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
              {[...Array(6)].map((_, i) => (
                <div key={i} className="card p-6">
                  <div className="skeleton h-48 rounded-xl mb-4"></div>
                  <div className="skeleton h-6 rounded mb-2"></div>
                  <div className="skeleton h-4 rounded mb-4"></div>
                  <div className="skeleton h-10 rounded"></div>
                </div>
              ))}
            </div>
          ) : contests.length === 0 ? (
            <div className="text-center py-16">
              <div className="w-24 h-24 bg-gray-200 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                <FiTrendingUp className="w-12 h-12 text-gray-400" />
              </div>
              <p className="text-xl text-gray-500 dark:text-gray-400">No contests available at the moment.</p>
            </div>
          ) : (
            <StaggerContainer className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
              {contests.map((contest, index) => (
                <StaggerItem key={contest._id}>
                  <motion.div
                    whileHover={{ y: -8 }}
                    className="card card-hover p-0 overflow-hidden group"
                  >
                    <div className="relative">
                      <img
                        src={contest.imageURL || `https://picsum.photos/400/250?random=${contest._id}`}
                        alt={contest.name}
                        className="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
                        onError={(e) => {
                          e.target.src = `https://picsum.photos/400/250?random=${Math.random()}`;
                        }}
                      />
                      <div className="absolute top-4 left-4">
                        <span className="px-3 py-1 bg-gradient-primary text-white text-sm font-semibold rounded-full">
                          Featured
                        </span>
                      </div>
                      <div className="absolute top-4 right-4">
                        <div className="flex items-center gap-1 px-2 py-1 bg-black/50 text-white text-sm rounded-full">
                          <FiUsers className="w-4 h-4" />
                          {contest.participants?.length || 0}
                        </div>
                      </div>
                    </div>
                    
                    <div className="p-6">
                      <h3 className="text-xl font-bold text-gray-900 dark:text-white mb-2 line-clamp-1">
                        {contest.name}
                      </h3>
                      <p className="text-gray-600 dark:text-gray-400 mb-4 line-clamp-2">
                        {contest.description || "Join this exciting contest and showcase your creativity!"}
                      </p>
                      
                      <div className="flex items-center justify-between mb-4">
                        <div className="flex items-center gap-2">
                          <FiDollarSign className="w-4 h-4 text-green-500" />
                          <span className="font-semibold text-green-600">
                            ${contest.prizeAmount || "500"}
                          </span>
                        </div>
                        <div className="flex items-center gap-1">
                          {[...Array(5)].map((_, i) => (
                            <FiStar key={i} className="w-4 h-4 text-yellow-400 fill-current" />
                          ))}
                        </div>
                      </div>
                      
                      <motion.button
                        onClick={() => handleDetailsClick(contest._id)}
                        whileHover={{ scale: 1.02 }}
                        whileTap={{ scale: 0.98 }}
                        className="w-full btn btn-primary group"
                      >
                        View Details
                        <FiArrowRight className="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" />
                      </motion.button>
                    </div>
                  </motion.div>
                </StaggerItem>
              ))}
            </StaggerContainer>
          )}

          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            className="text-center mt-12"
          >
            <Link to="/all-contests" className="btn btn-outline text-lg px-8 py-4">
              View All Contests
              <FiArrowRight className="w-5 h-5 ml-2" />
            </Link>
          </motion.div>
        </div>
      </section>

      {/* Features Section */}
      <section className="py-20">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            className="text-center mb-16"
          >
            <h2 className="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
              Why Choose ContestHub?
            </h2>
            <p className="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto">
              The ultimate platform for creative minds to compete, learn, and earn
            </p>
          </motion.div>

          <div className="grid grid-cols-1 md:grid-cols-3 gap-8">
            {features.map((feature, index) => {
              const Icon = feature.icon;
              return (
                <motion.div
                  key={index}
                  initial={{ opacity: 0, y: 20 }}
                  whileInView={{ opacity: 1, y: 0 }}
                  viewport={{ once: true }}
                  transition={{ delay: index * 0.2 }}
                  whileHover={{ y: -8 }}
                  className="card card-hover text-center p-8"
                >
                  <div className={`w-16 h-16 bg-gradient-to-r ${feature.color} rounded-2xl flex items-center justify-center mx-auto mb-6`}>
                    <Icon className="w-8 h-8 text-white" />
                  </div>
                  <h3 className="text-2xl font-bold text-gray-900 dark:text-white mb-4">
                    {feature.title}
                  </h3>
                  <p className="text-gray-600 dark:text-gray-400 leading-relaxed">
                    {feature.description}
                  </p>
                </motion.div>
              );
            })}
          </div>
        </div>
      </section>

      {/* Testimonials Section */}
      <section className="py-20 bg-gray-50 dark:bg-gray-900/50">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            className="text-center mb-16"
          >
            <h2 className="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
              Success Stories
            </h2>
            <p className="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto">
              Hear from our amazing community of winners and creators
            </p>
          </motion.div>

          <div className="grid grid-cols-1 md:grid-cols-3 gap-8">
            {testimonials.map((testimonial, index) => (
              <motion.div
                key={index}
                initial={{ opacity: 0, y: 20 }}
                whileInView={{ opacity: 1, y: 0 }}
                viewport={{ once: true }}
                transition={{ delay: index * 0.2 }}
                whileHover={{ y: -8 }}
                className="card card-hover p-8"
              >
                <div className="flex items-center mb-6">
                  <img
                    src={testimonial.avatar}
                    alt={testimonial.name}
                    className="w-12 h-12 rounded-full object-cover mr-4"
                  />
                  <div>
                    <h4 className="font-semibold text-gray-900 dark:text-white">
                      {testimonial.name}
                    </h4>
                    <p className="text-sm text-gray-500 dark:text-gray-400">
                      {testimonial.role}
                    </p>
                  </div>
                </div>
                
                <div className="flex items-center mb-4">
                  {[...Array(testimonial.rating)].map((_, i) => (
                    <FiStar key={i} className="w-5 h-5 text-yellow-400 fill-current" />
                  ))}
                </div>
                
                <p className="text-gray-600 dark:text-gray-400 mb-4 italic">
                  "{testimonial.content}"
                </p>
                
                <div className="text-sm text-purple-600 dark:text-purple-400 font-medium">
                  Winner of {testimonial.contest}
                </div>
              </motion.div>
            ))}
          </div>
        </div>
      </section>

      {/* CTA Section */}
      <section className="py-20 relative overflow-hidden">
        <div className="absolute inset-0 animated-gradient opacity-10"></div>
        <div className="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            className="card glass p-12"
          >
            <h2 className="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
              Ready to Start Winning?
            </h2>
            <p className="text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto">
              Join thousands of creators who have already earned amazing prizes and recognition for their work.
            </p>
            
            <div className="flex flex-col sm:flex-row gap-4 justify-center">
              {!isLoggedIn ? (
                <>
                  <motion.div whileHover={{ scale: 1.05 }} whileTap={{ scale: 0.95 }}>
                    <Link to="/register" className="btn btn-primary text-lg px-8 py-4">
                      <FiCheck className="w-5 h-5 mr-2" />
                      Join Free Today
                    </Link>
                  </motion.div>
                  <motion.div whileHover={{ scale: 1.05 }} whileTap={{ scale: 0.95 }}>
                    <Link to="/all-contests" className="btn btn-outline text-lg px-8 py-4">
                      <FiTrendingUp className="w-5 h-5 mr-2" />
                      Browse Contests
                    </Link>
                  </motion.div>
                </>
              ) : (
                <motion.div whileHover={{ scale: 1.05 }} whileTap={{ scale: 0.95 }}>
                  <Link to="/all-contests" className="btn btn-primary text-lg px-8 py-4">
                    <FiAward className="w-5 h-5 mr-2" />
